<header class="header">
      <div class="container header__container">
        <a href="/" class="header__logo">
          <img class="header__logotype" src="./src/assets/header/logo.svg" alt="whitepace" />
          <span class="header__name">whitepace</span>
        </a>

        <div class="header__wrapper-second">
          <nav class="header__nav nav">
            <ul class="nav__list">
              <li class="nav__item">
                <a href="#" class="nav__link">
                  Products
                  <img src="./src/assets/general/down-arrow.svg" alt="" class="nav__arrow" />
                </a>
              </li>
              <li class="nav__item">
                <a href="#" class="nav__link">
                  Solutions
                  <img src="./src/assets/general/down-arrow.svg" alt="" class="nav__arrow" />
